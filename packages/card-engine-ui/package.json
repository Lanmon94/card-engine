{
  "name": "@card-engine/ui",
  "version": "0.1.0",
  "description": "Taro + React card game UI components and animations",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Lanmon94/card-engine"
  },
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./adapter": "./src/adapter/index.ts",
    "./adapter/vite": "./src/adapter/vite.ts"
  },
  "files": [
    "src/"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@card-engine/core": "workspace:*"
  },
  "peerDependencies": {
    "@tarojs/components": ">=3.0.0",
    "react": ">=17.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "@types/react": "^18.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
